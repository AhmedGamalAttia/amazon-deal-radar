# ═══════════════════════════════════════════════════════════
# Deal Radar — Environment Variables
# Copy this file to .env.local (or set vars in Vercel dashboard).
# ═══════════════════════════════════════════════════════════

# Public site URL (used for sitemap, robots, OpenGraph tags)
# Locally:  http://localhost:3000
# Vercel:   https://your-project.vercel.app  (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Amazon Associates (US) tag — appended to every outbound Amazon link.
# Default in code: gemyi-20
NEXT_PUBLIC_AFFILIATE_TAG=gemyi-20
